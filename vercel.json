{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "public/**",
        "resources/**",
        "node_modules/react/umd/**",
        "node_modules/react-dom/umd/**"
      ]
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/resources/(.*)", "dest": "/api/index.js" },
    { "src": "/vendor/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
